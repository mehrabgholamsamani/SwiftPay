{
  "name": "corebank",
  "private": true,
  "packageManager": "pnpm@10.20.0",
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:integration": "node --test test/postgres.integration.test.mjs test/stage2-api.integration.test.mjs test/ledger.integration.test.mjs test/stage5-rail.integration.test.mjs",
    "format:check": "prettier --check .",
    "format": "prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.5",
    "@types/jest": "^29.5.14",
    "eslint": "^10.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.3.0",
    "jest": "^29.7.0",
    "testcontainers": "^10.16.0",
    "ts-jest": "^29.2.5",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0"
  },
  "lint-staged": {
    "*.ts": "prettier --write"
  }
}
